(kicad_pcb
  (version 20241229)
  (generator "pcbnew")
  (generator_version "9.0")
  (general
    (thickness 1.6))
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (44 "Edge.Cuts" user))
  (setup
    (stackup
      (layer "F.Cu" (type "copper") (thickness 0.035))
      (layer "dielectric 1" (type "core") (thickness 1.51))
      (layer "B.Cu" (type "copper") (thickness 0.035))))
  (net 0 "")
  (net 1 "+5V")
  (net 2 "GND")

  (gr_line (start 90 90) (end 130 90) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 130 90) (end 130 112) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 130 112) (end 90 112) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 90 112) (end 90 90) (layer "Edge.Cuts") (width 0.1))

  (segment (start 100 99) (end 120 99) (width 0.6) (layer "F.Cu") (net 1))

  (via (at 100 101) (size 0.8) (drill 0.4) (layers "F.Cu" "B.Cu") (net 2))
  (via (at 120 101) (size 0.8) (drill 0.4) (layers "F.Cu" "B.Cu") (net 2))

  (footprint "Resistor_SMD:R_0805"
    (layer "F.Cu")
    (at 100 100 0)
    (property "Reference" "U1")
    (property "Value" "SOURCE_5V")
    (property "PDN_ROLE" "SOURCE")
    (property "PDN_V" "5")
    (property "PDN_P_NET" "+5V")
    (property "PDN_N_NET" "GND")
    (pad "1" smd roundrect (at 0 -1) (size 1.2 1.0) (layers "F.Cu") (roundrect_rratio 0.25) (net 1 "+5V"))
    (pad "2" smd roundrect (at 0 1) (size 1.2 1.0) (layers "F.Cu") (roundrect_rratio 0.25) (net 2 "GND")))

  (footprint "Resistor_SMD:R_0805"
    (layer "F.Cu")
    (at 120 100 0)
    (property "Reference" "U2")
    (property "Value" "LOAD_1A")
    (property "PDN_ROLE" "SINK")
    (property "PDN_I" "1")
    (property "PDN_P_NET" "+5V")
    (property "PDN_N_NET" "GND")
    (pad "1" smd roundrect (at 0 -1) (size 1.2 1.0) (layers "F.Cu") (roundrect_rratio 0.25) (net 1 "+5V"))
    (pad "2" smd roundrect (at 0 1) (size 1.2 1.0) (layers "F.Cu") (roundrect_rratio 0.25) (net 2 "GND")))

  (zone
    (net 2)
    (net_name "GND")
    (layer "B.Cu")
    (hatch edge 0.5)
    (filled_polygon
      (layer "B.Cu")
      (pts
        (xy 92 92) (xy 128 92) (xy 128 110) (xy 92 110))))
)
